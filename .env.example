# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invoice_payment_predictor

# Stripe hosted checkout URL used directly in the Buy button href
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_XXX

# Optional for client-side Stripe calls if you add them later
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX

# Used to validate incoming Stripe webhook signatures
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# Optional Lemon Squeezy webhook signing secret for /api/webhooks/lemon-squeezy
LEMON_SQUEEZY_WEBHOOK_SECRET=
